{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "~/**": "allow",
      "/tmp/**": "allow"
    },
    "read": {
      "*": "allow",
      "~/**": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": {
      "*": "allow",
      "~/**": "allow"
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": true
    }
  }
}
